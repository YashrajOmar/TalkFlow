# TalkFlow Environment Variables Template
# Copy this file to '.env' if you deploy a local proxy or container.
# Client-side: Configure these directly in the UI Settings dashboard.

# Google AI Studio Gemini Key
# Get a key from: https://aistudio.google.com/
GEMINI_API_KEY="your_api_key_here"

# Default Model Selection
# Recommended options: gemini-2.5-flash, gemini-2.5-pro, gemini-1.5-flash
GEMINI_MODEL="gemini-2.5-flash"
