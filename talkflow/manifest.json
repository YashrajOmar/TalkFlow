{
  "manifest_version": 3,
  "name": "TalkFlow - Interview Speech Coach",
  "version": "1.0.0",
  "description": "Privacy-first interview coach — records, transcribes, and analyzes speech using local Whisper + Ollama. Cloud providers optional.",
  "permissions": [
    "activeTab",
    "tabs",
    "tabCapture",
    "sidePanel",
    "storage",
    "windows",
    "identity"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "https://www.googleapis.com/*",
    "https://accounts.google.com/*",
    "https://api.openai.com/*",
    "http://127.0.0.1:8765/*",
    "http://localhost:8765/*"
  ],
  "oauth2": {
    "client_id": "REPLACE_WITH_YOUR_GOOGLE_OAUTH_CLIENT_ID.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/drive.appdata"
    ]
  },
  "web_accessible_resources": [
    {
      "resources": ["permission.html", "permission.js", "vendor/lucide.min.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open TalkFlow"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "minimum_chrome_version": "116",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
